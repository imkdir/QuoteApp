# QuoteApp backend environment variables

# Required for /livekit/token to mint real tokens.
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Backend host/port used by scripts and local runs.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
