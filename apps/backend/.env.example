# QuoteApp backend environment variables

# Required for /livekit/token to mint real tokens.
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Backend host/port used by scripts and local runs.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Backend tutor TTS configuration (real backend inference path).
TUTOR_TTS_PROVIDER=auto
# Optional global overrides (otherwise provider-specific defaults are used):
# TUTOR_TTS_MODEL=
# TUTOR_TTS_VOICE=
TUTOR_TTS_SPEED=1.0
TUTOR_TTS_TIMEOUT_SECONDS=30
# OpenAI path:
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Gemini path:
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
